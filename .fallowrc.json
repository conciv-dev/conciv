{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "**/dist/**",
    "**/build/**",
    "**/.turbo/**",
    "**/*.d.ts",
    "**/*.generated.ts",
    "packages/aidx/**",
    "apps/examples/**",
    "e2e/astro/**",
    "e2e/nextjs/**",
    "e2e/solid-start/**",
    "e2e/svelte/**",
    "e2e/tanstack-start/**",
    "e2e/vite-react/**",
    "e2e/vite-solid/**",
    "e2e/vite-vanilla/**",
    "**/vitest.config.ts",
    "**/*.stories.tsx",
    "**/*.test-d.ts",
    "**/*.fixtures.ts",
    "packages/ui-kit-chat/src/store/story-connection.ts"
  ],
  "duplicates": {
    "minOccurrences": 3
  },
  "health": {
    "maxCyclomatic": 20,
    "maxCrap": 30
  },
  "rules": {
    "unused-exports": "warn",
    "unused-dependencies": "warn",
    "unused-dev-dependencies": "warn",
    "circular-dependencies": "warn"
  },
  "ignoreDependencies": [
    "collections",
    "@conciv/cli",
    "jazz-napi",
    "@oxlint/plugins",
    "@ark-ui/solid",
    "@conciv/client",
    "@conciv/embed",
    "@conciv/grab",
    "@conciv/mascot",
    "@conciv/solid-streamdown",
    "@conciv/ui-kit-chat",
    "@conciv/ui-kit-chat-tools",
    "@conciv/ui-kit-system",
    "bippy",
    "react-grab"
  ],
  "ignoreUnresolvedImports": ["collections/*"],
  "publicPackages": [
    "@conciv/core",
    "@conciv/embed",
    "@conciv/extension",
    "@conciv/extension-test-runner",
    "@conciv/extension-whiteboard",
    "@conciv/grab",
    "@conciv/harness",
    "@conciv/harness-testkit",
    "@conciv/it",
    "@conciv/mascot",
    "@conciv/plugin",
    "@conciv/protocol",
    "@conciv/solid-diffs",
    "@conciv/solid-streamdown",
    "@conciv/tools",
    "@conciv/ui-kit-chat",
    "@conciv/ui-kit-chat-tools",
    "@conciv/ui-kit-system",
    "@conciv/ui-kit-tap"
  ],
  "ignoreExports": [
    {
      "file": "apps/site/src/components/ui/**",
      "exports": ["*"]
    },
    {
      "file": "packages/ui-kit-chat/src/styled/**",
      "exports": ["*"]
    }
  ],
  "entry": ["packages/extension-testkit/src/host/host-entry.tsx"]
}
