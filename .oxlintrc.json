{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "unicorn"],
  "jsPlugins": [{"name": "unocss", "specifier": "@unocss/eslint-plugin"}],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "unicorn/consistent-function-scoping": "off",
    "unicorn/require-module-specifiers": "off",
    "react/react-in-jsx-scope": "off",
    "no-underscore-dangle": [
      "warn",
      {
        "allow": [
          "__MANDARAX__",
          "__MANDARAX_API_BASE__",
          "__MANDARAX_PAGE_DRIVER__",
          "__MANDARAX_REACT_BRIDGE__",
          "__MANDARAX_RENDER_TEST_CARD__",
          "__REACT_GRAB_DISABLED__",
          "__sdkStats",
          "__sdkReset",
          "_debugHookTypes",
          "_debugStack",
          "_context",
          "_splat"
        ]
      }
    ],
    "unocss/order": "warn",
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@ark-ui", "@ark-ui/**"],
            "importNames": ["Collapsible", "HoverCard", "ScrollArea", "Combobox", "Progress", "EnvironmentProvider"],
            "message": "Import design-system components from @mandarax/ui-kit-system, not @ark-ui directly. Only ui-kit-system may wrap Ark UI components. (Headless hooks like useListCollection / useFilter may still be imported from @ark-ui.)"
          }
        ]
      }
    ]
  },
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "overrides": [
    {
      "files": ["packages/ui-kit-system/**"],
      "rules": {
        "no-restricted-imports": "off"
      }
    },
    {
      "files": ["packages/solid-streamdown/**"],
      "rules": {
        "unocss/order": "off"
      }
    },
    {
      "files": ["apps/**"],
      "rules": {
        "unocss/order": "off"
      }
    }
  ],
  "ignorePatterns": ["dist", "build", "node_modules", ".turbo"]
}
