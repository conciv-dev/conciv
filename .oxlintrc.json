{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "unicorn"],
  "jsPlugins": [
    {"name": "unocss", "specifier": "@unocss/eslint-plugin"},
    {"name": "playwright", "specifier": "eslint-plugin-playwright"},
    {"name": "conciv", "specifier": "./tools/oxlint/no-comments.js"}
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "conciv/no-comments": "error",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/require-module-specifiers": "off",
    "react/react-in-jsx-scope": "off",
    "react/no-unstable-nested-components": "off",
    "no-underscore-dangle": [
      "warn",
      {
        "allow": [
          "__conciv",
          "__CONCIV__",
          "__CONCIV_API_BASE__",
          "__CONCIV_PAGE_DRIVER__",
          "__CONCIV_REACT_BRIDGE__",
          "__CONCIV_RENDER_TEST_CARD__",
          "__REACT_GRAB_DISABLED__",
          "__sdkStats",
          "__sdkReset",
          "__commandsCacheSet",
          "__client",
          "__server",
          "__render",
          "__execute",
          "__card",
          "__expand",
          "__ctx",
          "__scripted",
          "__turnMessages",
          "__TSR_ROUTER__",
          "__TSR_index",
          "_rbsplitInstance",
          "_debugHookTypes",
          "_debugStack",
          "_context",
          "_splat"
        ]
      }
    ],
    "unocss/order": "warn",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@hono/node-server",
            "importNames": ["serve", "createAdaptorServer", "getRequestListener"],
            "message": "Import serveHono from @conciv/serve, never @hono/node-server's serve — the wrapper bakes overrideGlobalObjects:false so a co-hosted engine never clobbers the host's global Response/Request (which breaks SSR realms, e.g. nitro rendering [object Response]). upgradeWebSocket may be imported directly."
          }
        ],
        "patterns": [
          {
            "group": ["@ark-ui", "@ark-ui/**"],
            "allowImportNames": ["useListCollection", "useFilter"],
            "message": "Import Ark UI components from @conciv/ui-kit-system, never @ark-ui directly — only ui-kit-system may wrap Ark UI. The headless hooks useListCollection / useFilter are the ONLY @ark-ui imports allowed elsewhere."
          }
        ]
      }
    ]
  },
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "overrides": [
    {
      "files": ["packages/ui-kit-system/**"],
      "rules": {
        "no-restricted-imports": "off"
      }
    },
    {
      "files": ["packages/serve/**"],
      "rules": {
        "no-restricted-imports": "off"
      }
    },
    {
      "files": [
        "packages/extensions/terminal/src/server/**",
        "packages/extensions/terminal/test/**",
        "packages/ui-kit-terminal/**"
      ],
      "rules": {
        "no-control-regex": "off"
      }
    },
    {
      "files": ["**/*.worker.ts", "apps/site/src/components/landing/demo/use-local-model.ts"],
      "rules": {
        "unicorn/require-post-message-target-origin": "off"
      }
    },
    {
      "files": ["packages/solid-streamdown/**", "packages/page/**"],
      "rules": {
        "unocss/order": "off"
      }
    },
    {
      "files": ["apps/**"],
      "rules": {
        "unocss/order": "off"
      }
    },
    {
      "files": ["packages/extensions/**/test/**", "packages/extension-testkit/**/test/**"],
      "rules": {
        "playwright/no-raw-locators": "error",
        "playwright/no-eval": "error",
        "playwright/no-element-handle": "error",
        "playwright/prefer-native-locators": "error"
      }
    },
    {
      "files": ["packages/extensions/**/test/fixtures/**"],
      "rules": {
        "playwright/no-raw-locators": "off",
        "playwright/no-eval": "off",
        "playwright/no-element-handle": "off",
        "playwright/prefer-native-locators": "off"
      }
    }
  ],
  "ignorePatterns": [
    "dist",
    "build",
    "node_modules",
    ".turbo",
    ".conciv",
    "**/*.gen.ts",
    "**/*.gen.tsx",
    "**/test-results",
    "packages/plugin/test/fixtures/**",
    "packages/extensions/tanstack/test/fixtures/**",
    "e2e/*/src",
    "e2e/*/app"
  ]
}
