{
  "name": "@mandarax/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "An embeddable AI dev agent for your running app — chat, page control, and live tests, injected into the page via a Vite plugin.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "prek install",
    "dev": "turbo run dev --filter=tanstack-start-example",
    "dev:site": "turbo run dev --filter=site",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "changeset": "changeset",
    "release:version": "mandarax-publish version",
    "release:check": "mandarax-publish check",
    "release": "mandarax-publish release",
    "release:snapshot": "mandarax-publish snapshot"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@j178/prek": "^0.4.5",
    "@mandarax/publish": "workspace:*",
    "@types/node": "^22.19.21",
    "@unocss/eslint-plugin": "66.7.2",
    "eslint-plugin-playwright": "2.10.4",
    "fallow": "2.98.0",
    "netlify-cli": "^26.1.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "publint": "^0.3.21",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0"
}
