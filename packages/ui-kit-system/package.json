{
  "name": "@conciv/ui-kit-system",
  "version": "0.0.13",
  "description": "Internal to @conciv/it (installed automatically, do not install directly). The conciv design system: SolidJS primitives (Button + Ark-UI-based Collapsible, HoverCard, ScrollArea, Combobox, Progress) styled with the shared UnoCSS preset, so every surface looks and behaves identically. Each component is viewable in Storybook.",
  "keywords": [
    "ark-ui",
    "conciv",
    "design-system",
    "solid-js",
    "ui-kit"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/ui-kit-system"
  },
  "files": [
    "dist",
    "src/tokens.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen:tokens": "node scripts/gen-tokens.ts",
    "build": "pnpm gen:tokens && vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run --passWithNoTests",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only --exclude-entrypoints tokens.css"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.37.1",
    "lucide-solid": "^1.18.0"
  },
  "devDependencies": {
    "@conciv/uno-preset": "workspace:*",
    "@types/node": "^22.19.21",
    "@unocss/postcss": "^66.7.2",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "playwright": "^1.61.1",
    "postcss": "^8.5.6",
    "solid-js": "^1.9.13",
    "storybook": "^10.5.0",
    "storybook-solidjs-vite": "^10.6.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
