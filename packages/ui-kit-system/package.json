{
  "name": "@conciv/ui-kit-system",
  "version": "0.0.4",
  "description": "The conciv design system: SolidJS primitives (Button + Ark-UI-based Collapsible, HoverCard, ScrollArea, Combobox, Progress) styled with the shared UnoCSS preset, so every surface looks and behaves identically. Each component is viewable in Storybook.",
  "keywords": [
    "ark-ui",
    "conciv",
    "design-system",
    "solid-js",
    "ui-kit"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/ui-kit-system"
  },
  "files": [
    "dist",
    "src/tokens.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen:tokens": "node scripts/gen-tokens.ts",
    "build": "pnpm gen:tokens && vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run --passWithNoTests",
    "storybook": "storybook dev -p 6008",
    "build-storybook": "storybook build",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only --exclude-entrypoints tokens.css"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.37.1",
    "lucide-solid": "^1.18.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@conciv/uno-preset": "workspace:*",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-vitest": "^10.4.4",
    "@types/node": "^22.19.21",
    "@unocss/postcss": "^66.7.2",
    "@unocss/reset": "^66.7.2",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "playwright": "^1.60.0",
    "postcss": "^8.5.6",
    "solid-js": "^1.9.13",
    "storybook": "^10.4.4",
    "storybook-solidjs-vite": "^10.3.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
