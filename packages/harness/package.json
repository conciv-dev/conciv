{
  "name": "@opendui/aidx-harness",
  "version": "0.0.0",
  "description": "Harness adapters (claude, codex, + stubs) behind the @opendui/aidx-protocol HarnessAdapter contract.",
  "license": "MIT",
  "files": [
    "dist",
    "plugins"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./claude": {
      "types": "./dist/claude/index.d.ts",
      "import": "./dist/claude/index.js"
    },
    "./codex": {
      "types": "./dist/codex/index.d.ts",
      "import": "./dist/codex/index.js"
    },
    "./gemini-cli": {
      "types": "./dist/gemini-cli/index.d.ts",
      "import": "./dist/gemini-cli/index.js"
    },
    "./opencode": {
      "types": "./dist/opencode/index.d.ts",
      "import": "./dist/opencode/index.js"
    },
    "./pi": {
      "types": "./dist/pi/index.d.ts",
      "import": "./dist/pi/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@opendui/aidx-protocol": "workspace:*",
    "@tanstack/ai": "^0.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
