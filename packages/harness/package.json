{
  "name": "@conciv/harness",
  "version": "0.0.15",
  "description": "Internal to @conciv/it (installed automatically, do not install directly). Harness adapters (claude, codex, + stubs) behind the @conciv/protocol HarnessAdapter contract.",
  "keywords": [
    "ai",
    "claude",
    "codex",
    "conciv",
    "gemini",
    "harness"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/harness"
  },
  "files": [
    "dist",
    "plugins"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./claude": {
      "types": "./dist/claude/index.d.ts",
      "import": "./dist/claude/index.js"
    },
    "./codex": {
      "types": "./dist/codex/index.d.ts",
      "import": "./dist/codex/index.js"
    },
    "./gemini-cli": {
      "types": "./dist/gemini-cli/index.d.ts",
      "import": "./dist/gemini-cli/index.js"
    },
    "./opencode": {
      "types": "./dist/opencode/index.d.ts",
      "import": "./dist/opencode/index.js"
    },
    "./pi": {
      "types": "./dist/pi/index.d.ts",
      "import": "./dist/pi/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.25.0",
    "@anthropic-ai/claude-agent-sdk": "^0.3.179",
    "@conciv/protocol": "workspace:^",
    "@opencode-ai/sdk": "^1.17.4",
    "@tanstack/ai": "^0.41.0",
    "@tanstack/ai-sandbox": "0.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@conciv/vitest-config": "workspace:*",
    "@tanstack/ai-acp": "0.2.2",
    "@tanstack/ai-claude-code": "0.2.2",
    "@tanstack/ai-codex": "0.2.2",
    "@tanstack/ai-opencode": "0.2.2",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.8",
    "tsdown": "^0.22.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
