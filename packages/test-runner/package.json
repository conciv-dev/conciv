{
  "name": "@mandarax/test-runner",
  "version": "0.0.0",
  "description": "Runner-agnostic test-runner adapters for mandarax (vitest today; jest/node-test/playwright are drop-in via the ChildRunnerSpec seam). Each adapter spawns a clean child that streams TestEvent NDJSON on fd 3.",
  "keywords": [
    "jest",
    "mandarax",
    "playwright",
    "test-runner",
    "vitest"
  ],
  "homepage": "https://github.com/mandarax-dev/mandarax/tree/main/packages/test-runner#readme",
  "bugs": "https://github.com/mandarax-dev/mandarax/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarax-dev/mandarax.git",
    "directory": "packages/test-runner"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./vitest": {
      "types": "./dist/vitest/vitest.d.ts",
      "import": "./dist/vitest/vitest.js"
    },
    "./jest": {
      "types": "./dist/jest/jest.d.ts",
      "import": "./dist/jest/jest.js"
    },
    "./node-test": {
      "types": "./dist/node-test/node-test.d.ts",
      "import": "./dist/node-test/node-test.js"
    },
    "./playwright": {
      "types": "./dist/playwright/playwright.d.ts",
      "import": "./dist/playwright/playwright.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@mandarax/protocol": "workspace:^",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
