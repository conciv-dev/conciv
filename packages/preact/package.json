{
  "name": "@conciv/preact",
  "version": "0.0.16",
  "description": "Preact component for the conciv widget: render <ConcivWidget /> to mount the conciv dev agent in any Preact app.",
  "keywords": [
    "ai",
    "chat",
    "conciv",
    "preact",
    "widget"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/preact"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vite build --config vite.fixture.config.ts && vitest run",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@conciv/embed": "workspace:^"
  },
  "devDependencies": {
    "@conciv/extension-terminal": "workspace:^",
    "@conciv/extension-testkit": "workspace:^",
    "@conciv/vitest-config": "workspace:*",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.8",
    "playwright": "^1.61.1",
    "preact": "^10.29.7",
    "publint": "^0.3.14",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "preact": ">=10"
  },
  "engines": {
    "node": ">=22.13"
  }
}
