{
  "name": "@conciv/ui-kit-tap",
  "version": "0.0.10",
  "description": "Internal to @conciv/it (installed automatically, do not install directly). TipTap-based rich-text primitives for conciv (SolidJS, shadow-DOM-safe): a mention composer built on @tiptap/core and the shared ui-kit-system tokens. Each primitive is viewable in Storybook.",
  "keywords": [
    "conciv",
    "prosemirror",
    "rich-text",
    "solid-js",
    "tiptap",
    "ui-kit"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/ui-kit-tap"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run --passWithNoTests",
    "storybook": "storybook dev -p 6009",
    "build-storybook": "storybook build",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@conciv/ui-kit-system": "workspace:*",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-document": "^3.27.1",
    "@tiptap/extension-hard-break": "^3.27.1",
    "@tiptap/extension-mention": "^3.27.1",
    "@tiptap/extension-paragraph": "^3.27.1",
    "@tiptap/extension-text": "^3.27.1",
    "@tiptap/pm": "^3.27.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@conciv/uno-preset": "workspace:*",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@types/node": "^22.19.21",
    "@unocss/postcss": "^66.7.2",
    "@unocss/reset": "^66.7.2",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "@zag-js/focus-visible": "1.41.2",
    "playwright": "^1.61.1",
    "postcss": "^8.5.6",
    "solid-js": "^1.9.13",
    "storybook": "^10.5.0",
    "storybook-solidjs-vite": "^10.6.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
