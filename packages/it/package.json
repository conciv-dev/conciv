{
  "name": "@conciv/it",
  "version": "0.0.9",
  "description": "Conceive it. The conciv dev agent, one install. Plugin for vite, webpack, rspack, rollup, esbuild, nextjs.",
  "keywords": [
    "ai",
    "conciv",
    "dev-agent",
    "embeddable",
    "vite-plugin"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/it"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./plugin/vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./plugin/webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js"
    },
    "./plugin/rspack": {
      "types": "./dist/rspack.d.ts",
      "import": "./dist/rspack.js"
    },
    "./plugin/rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.js"
    },
    "./plugin/esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js"
    },
    "./plugin/nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js",
      "default": "./dist/nextjs.js"
    },
    "./plugin/nextjs/widget": {
      "types": "./dist/nextjs-widget.d.ts",
      "import": "./dist/nextjs-widget.js",
      "default": "./dist/nextjs-widget.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@conciv/embed": "workspace:^",
    "@conciv/extension-terminal": "workspace:^",
    "@conciv/extension-test-runner": "workspace:^",
    "@conciv/extension-whiteboard": "workspace:^",
    "@conciv/plugin": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "next": "^15.3.0 || ^16.0.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  }
}
