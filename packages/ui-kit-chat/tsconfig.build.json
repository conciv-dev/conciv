{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/fixtures.ts",
    "src/**/fixtures.tsx",
    "src/**/story-connection.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
