{
  "name": "@conciv/core",
  "version": "0.0.13",
  "description": "Internal to @conciv/it (installed automatically, do not install directly). The conciv engine: a framework-free hono + @hono/node-server server exposing the /__pw HTTP surface, with a harness registry seam.",
  "keywords": [
    "ai",
    "conciv",
    "engine",
    "hono",
    "server"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/start.d.ts",
      "import": "./dist/start.js"
    },
    "./start": {
      "types": "./dist/start.d.ts",
      "import": "./dist/start.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@conciv/contract": "workspace:^",
    "@conciv/db": "workspace:^",
    "@conciv/extension": "workspace:^",
    "@conciv/harness": "workspace:^",
    "@conciv/protocol": "workspace:^",
    "@conciv/serve": "workspace:^",
    "@conciv/tools": "workspace:^",
    "@jridgewell/trace-mapping": "0.3.31",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orpc/server": "^1.14.7",
    "@tanstack/ai": "^0.41.0",
    "@tanstack/ai-sandbox": "^0.2.3",
    "@tanstack/ai-sandbox-local-process": "^0.2.0",
    "drizzle-orm": "1.0.0-rc.4",
    "get-port": "^7.1.0",
    "hono": "^4.12.0",
    "ufo": "^1.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@conciv/harness-testkit": "workspace:^",
    "@conciv/vitest-config": "workspace:*",
    "@hono/node-server": "^2.0.8",
    "@jridgewell/gen-mapping": "^0.3.13",
    "@tanstack/ai-mcp": "^0.2.3",
    "@types/node": "^22.19.21",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "tsdown": "^0.22.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  }
}
