{
  "name": "@mandarax/core",
  "version": "0.0.0",
  "description": "The mandarax engine: a framework-free h3 + srvx server exposing the /__pw HTTP surface, with harness + test-runner registry seams.",
  "keywords": [
    "ai",
    "engine",
    "h3",
    "mandarax",
    "server",
    "srvx"
  ],
  "homepage": "https://github.com/mandarax-dev/mandarax/tree/main/packages/core#readme",
  "bugs": "https://github.com/mandarax-dev/mandarax/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarax-dev/mandarax.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./widget-tags": {
      "types": "./dist/widget-tags.d.ts",
      "import": "./dist/widget-tags.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "0.3.31",
    "@mandarax/extensions": "workspace:^",
    "@mandarax/harness": "workspace:^",
    "@mandarax/protocol": "workspace:^",
    "@mandarax/test-runner": "workspace:^",
    "@mandarax/tools": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/ai": "^0.28.0",
    "get-port": "^7.1.0",
    "h3": "2.0.1-rc.22",
    "oxc-parser": "^0.127.0",
    "srvx": "^0.11.16",
    "ufo": "^1.6.4",
    "unstorage": "^1.17.5",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jridgewell/gen-mapping": "^0.3.13",
    "@tanstack/ai-mcp": "^0.1.0",
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
