{
  "name": "@conciv/uno-preset",
  "version": "0.0.16",
  "private": true,
  "description": "Shared conciv UnoCSS preset: presetMini + presetTypography (themed to the --pw-* tokens) + the sr-only shortcut. One source of truth reused by every package's uno.config so spacing/prose/shortcuts never drift.",
  "homepage": "https://conciv.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/uno-preset"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@unocss/preset-typography": "^66.7.2",
    "@unocss/preset-wind4": "^66.7.2"
  },
  "devDependencies": {
    "@conciv/vitest-config": "workspace:*",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "unocss": "^66.7.2"
  }
}
