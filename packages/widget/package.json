{
  "name": "@conciv/widget",
  "version": "0.0.4",
  "description": "The conciv in-page widget: a SolidJS chat UI mounted into a Shadow DOM that talks to the dev server over SSE, plus the page-control driver the agent drives.",
  "keywords": [
    "ai",
    "chat",
    "conciv",
    "solid-js",
    "widget"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/widget"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/mount.d.ts",
      "import": "./dist/mount.js",
      "default": "./dist/mount.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && vite build --config vite.global.config.ts && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "storybook": "storybook dev -p 6009",
    "build-storybook": "storybook build",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.37.1",
    "@conciv/api-client": "workspace:^",
    "@conciv/extension": "workspace:^",
    "@conciv/grab": "workspace:^",
    "@conciv/protocol": "workspace:^",
    "@conciv/solid-diffs": "workspace:^",
    "@conciv/solid-streamdown": "workspace:^",
    "@conciv/ui-kit-chat": "workspace:^",
    "@conciv/ui-kit-chat-tools": "workspace:^",
    "@conciv/ui-kit-system": "workspace:^",
    "@tanstack/ai": "^0.28.0",
    "@tanstack/ai-client": "^0.16.3",
    "@tanstack/ai-solid": "^0.13.4",
    "@tanstack/solid-hotkeys": "^0.10.0",
    "@tanstack/solid-pacer": "^0.21.1",
    "bippy": "0.5.41",
    "gsap": "^3.15.0",
    "lucide-solid": "^1.18.0",
    "react-grab": "^0.1.44",
    "shiki": "^4.2.0",
    "solid-js": "^1.9.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@conciv/extension-test-runner": "workspace:^",
    "@conciv/uno-preset": "workspace:*",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-vitest": "^10.4.4",
    "@types/node": "^22.19.21",
    "@unocss/postcss": "^66.7.2",
    "@unocss/reset": "^66.7.2",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "playwright": "^1.60.0",
    "postcss": "^8.5.6",
    "storybook": "^10.4.4",
    "storybook-solidjs-vite": "^10.3.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  }
}
