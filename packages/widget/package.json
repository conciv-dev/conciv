{
  "name": "@devgent/widget",
  "version": "0.0.0",
  "description": "The devgent in-page widget: a React chat UI mounted into a Shadow DOM that talks to the dev server over SSE, plus the page-control driver the agent drives.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/mount.d.ts",
      "import": "./dist/mount.js"
    },
    "./global": "./dist/devgent-widget.global.js"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@devgent/protocol": "workspace:*",
    "@tanstack/ai": "0.28.0",
    "@tanstack/ai-client": "0.16.3",
    "@tanstack/ai-react": "0.15.4",
    "marked": "18.0.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shiki": "4.2.0"
  },
  "devDependencies": {
    "@types/node": "22.19.7",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "playwright": "1.60.0",
    "typescript": "5.9.3",
    "vite": "7.0.0",
    "vitest": "4.1.8"
  }
}
