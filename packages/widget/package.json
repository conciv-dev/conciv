{
  "name": "@opendui/aidx-widget",
  "version": "0.0.0",
  "description": "The aidx in-page widget: a SolidJS chat UI mounted into a Shadow DOM that talks to the dev server over SSE, plus the page-control driver the agent drives.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/mount.d.ts",
      "import": "./dist/mount.js"
    },
    "./global": "./dist/aidx-widget.global.js"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.37.1",
    "@floating-ui/dom": "^1.7.6",
    "@opendui/aidx-protocol": "workspace:*",
    "@opendui/aidx-solid-diffs": "workspace:*",
    "@opendui/aidx-solid-streamdown": "workspace:*",
    "@opendui/aidx-tool-ui": "workspace:*",
    "@tanstack/ai": "^0.28.0",
    "@tanstack/ai-client": "^0.16.3",
    "@tanstack/ai-solid": "^0.13.4",
    "@tanstack/solid-hotkeys": "^0.10.0",
    "@tanstack/solid-pacer": "^0.21.1",
    "bippy": "0.5.41",
    "lucide-solid": "^1.18.0",
    "react-grab": "^0.1.44",
    "shiki": "^4.2.0",
    "solid-js": "^1.9.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  }
}
