  "description": "Internal release tooling for the aidx monorepo: normalize package metadata, version, and publish via changesets. citty command tree.",
  "homepage": "https://conciv.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/publish"
  },
  "bin": {
    "conciv-publish": "./src/cli.ts"
  },
