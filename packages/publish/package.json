    "test": "vitest run"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "execa": "^9.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@conciv/vitest-config": "workspace:*",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.8",
