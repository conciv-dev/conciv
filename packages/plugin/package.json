{
  "name": "@mandarax/plugin",
  "version": "0.0.0",
  "description": "The mandarax dev agent as an unplugin: vite (full — viteBridge + widget middleware + boot), webpack/rspack (boot the engine), rollup/esbuild (build-only no-ops). One factory, per-bundler subpath entries.",
  "keywords": [
    "esbuild",
    "mandarax",
    "nextjs",
    "rollup",
    "rspack",
    "vite-plugin",
    "webpack"
  ],
  "homepage": "https://github.com/mandarax-dev/mandarax/tree/main/packages/plugin#readme",
  "bugs": "https://github.com/mandarax-dev/mandarax/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarax-dev/mandarax.git",
    "directory": "packages/plugin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js"
    },
    "./rspack": {
      "types": "./dist/rspack.d.ts",
      "import": "./dist/rspack.js"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.js"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.js",
      "default": "./dist/nextjs.js"
    },
    "./nextjs/widget": {
      "types": "./dist/nextjs-widget.d.ts",
      "import": "./dist/nextjs-widget.js",
      "default": "./dist/nextjs-widget.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@mandarax/cli": "workspace:^",
    "@mandarax/core": "workspace:^",
    "@mandarax/extensions": "workspace:^",
    "@mandarax/protocol": "workspace:^",
    "@mandarax/widget": "workspace:^",
    "babel-preset-solid": "^1.9.12",
    "jiti": "^2.7.0",
    "launch-editor": "^2.14.1",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.127.0",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "next": "^15.3.0 || ^16.0.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  }
}
