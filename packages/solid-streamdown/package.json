{
  "name": "@conciv/solid-streamdown",
  "version": "0.0.9",
  "description": "Internal to @conciv/it (installed automatically, do not install directly). A SolidJS streaming-markdown renderer: a port of Vercel's streamdown (block memoization, incomplete-markdown handling, token fade-in) onto Solid + the unified pipeline. Encapsulated so the widget can swap it without churn.",
  "keywords": [
    "conciv",
    "markdown",
    "solid-js",
    "streaming"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/solid-streamdown"
  },
  "files": [
    "dist",
    "src/styles.css",
    "LICENSE-APACHE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only --exclude-entrypoints styles.css"
  },
  "dependencies": {
    "marked": "^18.0.5",
    "rehype-harden": "^1.1.8",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remend": "^1.3.0",
    "unified": "^11.0.5",
    "unist-util-visit-parents": "^6.0.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@types/hast": "^3.0.4",
    "@types/node": "^22.19.21",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "playwright": "^1.61.1",
    "solid-js": "^1.9.13",
    "storybook": "^10.5.0",
    "storybook-solidjs-vite": "^10.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "shiki": "^4.2.0",
    "solid-js": "^1.9.13"
  }
}
