{
  "name": "@mandarax/tool-ui",
  "version": "0.0.0",
  "description": "SolidJS tool-call renderers for the mandarax chat thread. tanstack-AI convention: render by tool name, reading zod-typed part.input/part.output. One view per tool, viewable in Storybook.",
  "keywords": [
    "ai-tools",
    "mandarax",
    "react",
    "shadcn",
    "tool-ui"
  ],
  "homepage": "https://github.com/mandarax-dev/mandarax/tree/main/packages/tool-ui#readme",
  "bugs": "https://github.com/mandarax-dev/mandarax/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarax-dev/mandarax.git",
    "directory": "packages/tool-ui"
  },
  "files": [
    "dist",
    "src/tokens.css",
    "src/tool-ui.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./tool-ui.css": "./src/tool-ui.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only --exclude-entrypoints tokens.css tool-ui.css"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.37.1",
    "@mandarax/protocol": "workspace:^",
    "@mandarax/solid-diffs": "workspace:^",
    "@mandarax/tools": "workspace:^",
    "@tanstack/solid-virtual": "^3.13.12",
    "js-beautify": "^1.15.4",
    "lucide-solid": "^1.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-vitest": "^10.4.4",
    "@tanstack/ai-client": "^0.16.3",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^22.19.21",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "playwright": "^1.60.0",
    "solid-js": "^1.9.13",
    "storybook": "^10.4.4",
    "storybook-solidjs-vite": "^10.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
