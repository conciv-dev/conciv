{
  "name": "@mandarax/protocol",
  "version": "0.0.0",
  "description": "Wire types shared by the mandarax vite-plugin and widget.",
  "keywords": [
    "ag-ui",
    "mandarax",
    "protocol",
    "types"
  ],
  "homepage": "https://github.com/mandarax-dev/mandarax/tree/main/packages/protocol#readme",
  "bugs": "https://github.com/mandarax-dev/mandarax/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarax-dev/mandarax.git",
    "directory": "packages/protocol"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./chat-types": {
      "types": "./dist/chat-types.d.ts",
      "import": "./dist/chat-types.js"
    },
    "./ui-types": {
      "types": "./dist/ui-types.d.ts",
      "import": "./dist/ui-types.js"
    },
    "./done-types": {
      "types": "./dist/done-types.d.ts",
      "import": "./dist/done-types.js"
    },
    "./test-types": {
      "types": "./dist/test-types.d.ts",
      "import": "./dist/test-types.js"
    },
    "./harness-types": {
      "types": "./dist/harness-types.d.ts",
      "import": "./dist/harness-types.js"
    },
    "./runner-types": {
      "types": "./dist/runner-types.d.ts",
      "import": "./dist/runner-types.js"
    },
    "./bundler-types": {
      "types": "./dist/bundler-types.d.ts",
      "import": "./dist/bundler-types.js"
    },
    "./config-types": {
      "types": "./dist/config-types.d.ts",
      "import": "./dist/config-types.js"
    },
    "./page-types": {
      "types": "./dist/page-types.d.ts",
      "import": "./dist/page-types.js"
    },
    "./page-introspect-types": {
      "types": "./dist/page-introspect-types.d.ts",
      "import": "./dist/page-introspect-types.js"
    },
    "./usage-types": {
      "types": "./dist/usage-types.d.ts",
      "import": "./dist/usage-types.js"
    },
    "./tool-view-types": {
      "types": "./dist/tool-view-types.d.ts",
      "import": "./dist/tool-view-types.js"
    },
    "./db-types": {
      "types": "./dist/db-types.d.ts",
      "import": "./dist/db-types.js"
    },
    "./sync-types": {
      "types": "./dist/sync-types.d.ts",
      "import": "./dist/sync-types.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@tanstack/ai": "^0.28.0",
    "@tanstack/ai-client": "^0.16.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "yjs": "^13.6.31"
  }
}
