{
  "name": "@devgent/protocol",
  "version": "0.0.0",
  "description": "Wire types shared by the devgent vite-plugin and widget.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./chat-types": {
      "types": "./dist/chat-types.d.ts",
      "import": "./dist/chat-types.js"
    },
    "./ui-types": {
      "types": "./dist/ui-types.d.ts",
      "import": "./dist/ui-types.js"
    },
    "./test-types": {
      "types": "./dist/test-types.d.ts",
      "import": "./dist/test-types.js"
    },
    "./vitest-types": {
      "types": "./dist/vitest-types.d.ts",
      "import": "./dist/vitest-types.js"
    },
    "./harness-types": {
      "types": "./dist/harness-types.d.ts",
      "import": "./dist/harness-types.js"
    },
    "./runner-types": {
      "types": "./dist/runner-types.d.ts",
      "import": "./dist/runner-types.js"
    },
    "./bundler-types": {
      "types": "./dist/bundler-types.d.ts",
      "import": "./dist/bundler-types.js"
    },
    "./page-protocol": {
      "types": "./dist/page-protocol.d.ts",
      "import": "./dist/page-protocol.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
