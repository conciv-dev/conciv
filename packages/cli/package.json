{
  "name": "@aidx/cli",
  "version": "0.0.0",
  "description": "The aidx agent-facing CLI: `aidx tools` (drive the live page/vite/tests) and `aidx ui` (render interactive UI in the chat). citty command tree, zod-validated args.",
  "license": "MIT",
  "bin": {
    "aidx": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./bin": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsdown && chmod +x dist/bin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@aidx/protocol": "workspace:*",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
