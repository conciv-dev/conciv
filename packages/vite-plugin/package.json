{
  "name": "@devgent/vite-plugin",
  "version": "0.0.0",
  "description": "DEPRECATED alias of @devgent/plugin (use @devgent/plugin/vite). Re-exports for one cycle.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
