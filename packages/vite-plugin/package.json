    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@devgent/core": "workspace:*",
    "@devgent/plugin": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "deprecated": "Use @devgent/plugin/vite instead."
}
