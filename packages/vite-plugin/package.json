{
  "name": "@devgent/vite-plugin",
  "version": "0.0.0",
  "description": "The devgent dev agent as a vite plugin: HTTP routes, claude -p spawn, out-of-process vitest runner, and the page-control bus.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@devgent/cli": "workspace:*",
    "@devgent/core": "workspace:*",
    "@devgent/protocol": "workspace:*",
    "@devgent/widget": "workspace:*",
    "launch-editor": "^2.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  }
}
