{
  "name": "@conciv/ui-kit-chat-tools",
  "version": "0.0.16",
  "description": "Internal to @conciv/it (installed automatically, do not install directly). The conciv tool-card vocabulary: concrete tool-call cards (Bash, Edit, Read, Search, Todo, apply_patch, page, ui, …) built on @conciv/ui-kit-chat's tool-building primitives + @conciv/ui-kit-system. ui-kit-chat stays tool-agnostic; this package knows the tools.",
  "keywords": [
    "ai-chat",
    "conciv",
    "solid-js",
    "ui-kit"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/ui-kit-chat-tools"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run --passWithNoTests",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@conciv/protocol": "workspace:^",
    "@conciv/solid-diffs": "workspace:^",
    "@conciv/tools": "workspace:^",
    "@conciv/ui-kit-chat": "workspace:^",
    "@conciv/ui-kit-system": "workspace:^",
    "js-beautify": "^1.15.4",
    "lucide-solid": "^1.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@conciv/uno-preset": "workspace:*",
    "@conciv/vitest-config": "workspace:*",
    "@tanstack/ai-client": "0.22.0",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^22.19.21",
    "@unocss/postcss": "^66.7.2",
    "@vitest/coverage-v8": "4.1.10",
    "postcss": "^8.5.6",
    "solid-js": "^1.9.13",
    "storybook": "^10.5.0",
    "storybook-solidjs-vite": "^10.6.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
