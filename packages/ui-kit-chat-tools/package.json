{
  "name": "@mandarax/ui-kit-chat-tools",
  "version": "0.0.0",
  "description": "The mandarax tool-card vocabulary: concrete tool-call cards (Bash, Edit, Read, Search, Todo, apply_patch, page, ui, …) built on @mandarax/ui-kit-chat's tool-building primitives + @mandarax/ui-kit-system. ui-kit-chat stays tool-agnostic; this package knows the tools.",
  "keywords": [
    "ai-chat",
    "mandarax",
    "solid-js",
    "tool-ui",
    "ui-kit"
  ],
  "homepage": "https://github.com/mandarax-dev/mandarax/tree/main/packages/ui-kit-chat-tools#readme",
  "bugs": "https://github.com/mandarax-dev/mandarax/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarax-dev/mandarax.git",
    "directory": "packages/ui-kit-chat-tools"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run --passWithNoTests",
    "storybook": "storybook dev -p 6010",
    "build-storybook": "storybook build",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@mandarax/protocol": "workspace:^",
    "@mandarax/solid-diffs": "workspace:^",
    "@mandarax/tools": "workspace:^",
    "@mandarax/ui-kit-chat": "workspace:^",
    "@mandarax/ui-kit-system": "workspace:^",
    "js-beautify": "^1.15.4",
    "lucide-solid": "^1.18.0",
    "shiki": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@mandarax/uno-preset": "workspace:*",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-vitest": "^10.4.4",
    "@tanstack/ai-client": "^0.16.3",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^22.19.21",
    "@unocss/postcss": "^66.7.2",
    "@unocss/reset": "^66.7.2",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "playwright": "^1.60.0",
    "postcss": "^8.5.6",
    "solid-js": "^1.9.13",
    "storybook": "^10.4.4",
    "storybook-solidjs-vite": "^10.3.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
