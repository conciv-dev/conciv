{
  "name": "@conciv/extension-ios",
  "version": "0.0.15",
  "description": "Internal to @conciv/it (installed automatically, do not install directly). The iOS built-in extension bridge protocol: zod schemas for the WKWebView page and native message contract, the platform-neutral page-side bridge client state machine, and cross-platform conformance fixtures.",
  "keywords": [
    "bridge",
    "conciv",
    "extension",
    "ios",
    "webview"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/extensions/ios"
  },
  "files": [
    "dist",
    "fixtures"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./bridge": {
      "types": "./dist/shared/bridge.d.ts",
      "import": "./dist/shared/bridge.js"
    },
    "./bridge-client": {
      "types": "./dist/shared/bridge-client.d.ts",
      "import": "./dist/shared/bridge-client.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && vite build && tsc -p tsconfig.build.json",
    "gen:fixtures": "node fixtures/bridge/gen.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@conciv/extension": "workspace:^",
    "@conciv/grab": "workspace:^",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@conciv/vitest-config": "workspace:*",
    "@types/node": "^22.19.21",
    "solid-js": "^1.9.13",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
