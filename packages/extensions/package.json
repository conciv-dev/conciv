{
  "name": "@mandarax/extensions",
  "version": "0.0.0",
  "description": "The mandarax extension system: the authoring contract (defineExtension/defineTool), discovery source, and server-side contribution collection shared by the widget, plugin, and core.",
  "keywords": [
    "extensions",
    "mandarax",
    "plugins"
  ],
  "homepage": "https://github.com/mandarax-dev/mandarax/tree/main/packages/extensions#readme",
  "bugs": "https://github.com/mandarax-dev/mandarax/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarax-dev/mandarax.git",
    "directory": "packages/extensions"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run --passWithNoTests",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@mandarax/ui-kit-system": "workspace:^",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "solid-js": "^1.9.13",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
