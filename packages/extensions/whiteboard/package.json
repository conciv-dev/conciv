{
  "name": "@mandarax/extension-whiteboard",
  "version": "0.0.0",
  "description": "The whiteboard built-in extension: an Excalidraw canvas the user and the AI share over the dev app, with source-anchored comments and pins, running on a self-hosted Jazz CRDT db on the @mandarax/extension contract.",
  "keywords": [
    "ai",
    "canvas",
    "excalidraw",
    "extension",
    "mandarax",
    "whiteboard"
  ],
  "homepage": "https://github.com/mandarax-dev/mandarax/tree/main/packages/extensions/whiteboard#readme",
  "bugs": "https://github.com/mandarax-dev/mandarax/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarax-dev/mandarax.git",
    "directory": "packages/extensions/whiteboard"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@excalidraw/mermaid-to-excalidraw": "^1.1.4",
    "@mandarax/extension": "workspace:^",
    "@mandarax/protocol": "workspace:^",
    "@mandarax/tool-ui": "workspace:^",
    "@mandarax/ui-kit-system": "workspace:^",
    "h3": "2.0.1-rc.22",
    "jazz-napi": "2.0.0-alpha.52",
    "jazz-tools": "2.0.0-alpha.52",
    "lucide-solid": "^1.18.0",
    "oxc-parser": "^0.127.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "solid-js": "^1.9.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mandarax/core": "workspace:^",
    "@mandarax/uno-preset": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@tanstack/ai-mcp": "^0.1.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/browser-playwright": "4.1.8",
    "get-port": "^7.2.0",
    "playwright": "^1.60.0",
    "srvx": "^0.11.16",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
