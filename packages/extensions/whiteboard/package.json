{
  "name": "@conciv/extension-whiteboard",
  "version": "0.0.7",
  "description": "The whiteboard built-in extension: an Excalidraw canvas the user and the AI share over the dev app, with source-anchored comments and pins, running on a local drizzle/libSQL db with an SSE-fed TanStack DB client on the @conciv/extension contract.",
  "keywords": [
    "ai",
    "canvas",
    "conciv",
    "excalidraw",
    "extension",
    "whiteboard"
  ],
  "homepage": "https://conciv.dev",
  "bugs": "https://github.com/conciv-dev/conciv/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "packages/extensions/whiteboard"
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@conciv/extension": "workspace:^",
    "@conciv/grab": "workspace:^",
    "@conciv/protocol": "workspace:^",
    "@conciv/ui-kit-chat": "workspace:^",
    "@conciv/ui-kit-chat-tools": "workspace:^",
    "@conciv/ui-kit-system": "workspace:^",
    "@conciv/ui-kit-tap": "workspace:^",
    "@excalidraw/excalidraw": "^0.18.1",
    "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
    "@hono/zod-validator": "^0.8.0",
    "@libsql/client": "^0.17.4",
    "@takumi-rs/core": "^1.8.7",
    "@takumi-rs/helpers": "^1.8.7",
    "@tanstack/solid-db": "^0.2.28",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.0",
    "lucide-solid": "^1.18.0",
    "oxc-parser": "^0.127.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "solid-js": "^1.9.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@conciv/extension-testkit": "workspace:^",
    "@conciv/harness-testkit": "workspace:^",
    "@conciv/uno-preset": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/browser-playwright": "4.1.9",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.61.1",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
