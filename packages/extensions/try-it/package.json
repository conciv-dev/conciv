{
  "name": "@conciv/extension-try-it",
  "version": "0.0.14",
  "private": true,
  "description": "Internal conciv.dev demo extension: renders the guided connect steps inside the widget panel and probes for a locally-connected agent core. Not published.",
  "keywords": [
    "conciv",
    "connect",
    "extension"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@conciv/extension": "workspace:^",
    "@conciv/protocol": "workspace:^",
    "@conciv/ui-kit-system": "workspace:^",
    "lucide-solid": "^1.18.0"
  },
  "devDependencies": {
    "@conciv/extension-testkit": "workspace:^",
    "@conciv/uno-preset": "workspace:*",
    "@conciv/vitest-config": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.19.21",
    "@vitest/coverage-v8": "^4.1.8",
    "solid-js": "^1.9.13",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  }
}
