{
  "name": "@mandarax/tools",
  "version": "0.0.0",
  "description": "mandarax agent tools as @tanstack/ai toolDefinition().server() functions: ui, page, test.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./defs": {
      "types": "./dist/defs.d.ts",
      "import": "./dist/defs.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "test": "vitest run"
  },
  "dependencies": {
    "@mandarax/protocol": "workspace:*",
    "@tanstack/ai": "^0.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
