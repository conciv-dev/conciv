{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "env": ["SKIP_STORYBOOK_TESTS", "CI"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "publint": {
      "dependsOn": ["build"]
    },
    "attw": {
      "dependsOn": ["build"]
    }
  }
}
