{
  "name": "site",
  "version": "0.0.13",
  "private": true,
  "homepage": "https://conciv.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conciv-dev/conciv.git",
    "directory": "apps/site"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "node scripts/copy-widget-bundle.mjs && node scripts/build-source-manifest.mjs && vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "fumadocs-mdx && tsc --noEmit",
    "lint": "oxlint",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "gen:snippets": "node --experimental-strip-types scripts/highlight-snippets.ts"
  },
  "dependencies": {
    "@conciv/embed": "workspace:*",
    "@conciv/extension-terminal": "workspace:*",
    "@conciv/extension-try-it": "workspace:*",
    "@conciv/it": "workspace:*",
    "@conciv/mascot": "workspace:*",
    "@conciv/protocol": "workspace:*",
    "@fontsource-variable/geist": "^5.2.9",
    "@gsap/react": "^2.1.2",
    "@huggingface/transformers": "^4.2.0",
    "@shikijs/magic-move": "^4.3.0",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.10.2",
    "fumadocs-mdx": "^15.0.12",
    "fumadocs-ui": "^16.10.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "^1.18.0",
    "mermaid": "^11.15.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.4",
    "@conciv/core": "workspace:*",
    "@conciv/extension-compiler": "workspace:*",
    "@conciv/harness-testkit": "workspace:*",
    "@conciv/try": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@types/mdx": "^2.0.14",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.61.1",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "twoslash": "^0.3.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.106.0"
  }
}
