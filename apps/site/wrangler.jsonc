{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "conciv-site",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {"pattern": "conciv.dev", "custom_domain": true},
    {"pattern": "www.conciv.dev", "custom_domain": true}
  ],
  "observability": {
    "enabled": true
  }
}
